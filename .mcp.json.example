{
  "_comment": "Example MCP server config. Copy to .mcp.json and trim to what you actually use. JSON has no comments, so the reasoning, the build-vs-use decision rule, and the 5-7 server cap live in docs/mcp.md. Keep the active set SMALL: more than ~5-7 connected servers measurably degrades agent performance through tool bloat. Secrets come from env vars (${VAR}), never inline.",

  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },

    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },

    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    }
  }
}
